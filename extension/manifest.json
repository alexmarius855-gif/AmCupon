{
  "manifest_version": 3,
  "name": "AmCupon.ro — Coduri de reducere",
  "short_name": "AmCupon",
  "version": "1.0.0",
  "description": "Gaseste automat coduri de reducere si oferte pentru magazinul pe care il vizitezi.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AmCupon — coduri de reducere"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://amcupon.ro/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
